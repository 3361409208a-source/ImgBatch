{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImgBatch",
  "version": "3.0.0",
  "identifier": "com.imgbatch.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ImgBatch",
        "width": 1100,
        "height": 850,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true
      },
      {
        "label": "quick",
        "create": false,
        "title": "ImgBatch 快捷操作",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/imgbatch-api"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "ImgBatch",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
